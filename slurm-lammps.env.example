# Copy to slurm-lammps.env and adjust (slurm-lammps.env is gitignored).
# Loaded by: make start-services-slurm  (and passed to API + UI processes)

RUN_SLURM_E2E=1
DOCKER_SLURM_CONTAINER=sci_slurm-gpu-worker-1

# Streamlit UI → API (default fine when API is on localhost:8000)
# HPC_API_URL=http://localhost:8000

# Optional — same as DOCKER_SLURM_CONTAINER if unset
# DOCKER_SLURM_SUBMIT_CONTAINER=

# LAMMPS_USE_SBATCH=1
# LAMMPS_BIN=lmp
# SBATCH_WAIT_TIMEOUT=600
